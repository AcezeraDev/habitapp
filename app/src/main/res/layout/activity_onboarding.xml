<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootOnboarding"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="720dp"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="32dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_soft_primary"
                android:contentDescription="@string/app_name"
                android:padding="10dp"
                android:src="@drawable/ic_app_icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HabitApp"
                    android:textColor="@color/ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Ajuste inicial da sua rotina"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtStep"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_onboarding_step"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="1 / 8"
                android:textColor="@color/primary_dark"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressOnboarding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:max="8"
            android:progress="1"
            app:indicatorColor="@color/primary"
            app:trackColor="@color/line"
            app:trackCornerRadius="10dp"
            app:trackThickness="9dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOnboardingPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_onboarding_prompt"
                android:orientation="vertical"
                android:padding="22dp">

                <ImageView
                    android:id="@+id/imgQuestionIcon"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_category_focus"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="12dp"
                    android:src="@drawable/ic_nav_goals"
                    app:tint="@color/primary" />

                <TextView
                    android:id="@+id/txtQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Como voce quer ser chamado?"
                    android:textColor="@color/ink"
                    android:textSize="29sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Vamos personalizar sua rotina diaria."
                    android:textColor="@color/muted"
                    android:textSize="16sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:hint="Resposta"
                    app:boxBackgroundColor="@color/surface"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxStrokeColor="@color/line"
                    app:startIconDrawable="@drawable/ic_nav_profile"
                    app:startIconTint="@color/primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/ink"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/optionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/optionOne"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:cornerRadius="22dp"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:strokeColor="@color/line" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/optionTwo"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="12dp"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:cornerRadius="22dp"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:strokeColor="@color/line" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/optionThree"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="12dp"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:cornerRadius="22dp"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:strokeColor="@color/line" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtOnboardingHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_onboarding_footer"
            android:paddingStart="16dp"
            android:paddingTop="13dp"
            android:paddingEnd="16dp"
            android:paddingBottom="13dp"
            android:text="Responda rapido. Depois voce pode ajustar tudo nas configuracoes."
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="0.82"
                android:text="Voltar"
                android:textAllCaps="false"
                android:textColor="@color/muted"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1.5"
                android:text="Continuar"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="22dp"
                app:icon="@drawable/ic_nav_goals"
                app:iconTint="@color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
