<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Metas"
            android:textColor="@color/ink"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMetasResumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ajuste o app ao seu ritmo."
            android:textColor="@color/muted"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/surface_elevated"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/txtMetaAgua"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Agua: 2.0 L"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderAgua"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stepSize="0.25"
                    android:valueFrom="1"
                    android:valueTo="4" />

                <TextView
                    android:id="@+id/txtMetaEstudo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Foco diario: 60 min"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderEstudo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stepSize="15"
                    android:valueFrom="15"
                    android:valueTo="180" />

                <TextView
                    android:id="@+id/txtMetaSessao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Sessao padrao: 25 min"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderSessao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stepSize="5"
                    android:valueFrom="10"
                    android:valueTo="60" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSalvarMetas"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:text="Salvar metas"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/coral"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtMetasInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Metas boas sao claras, visiveis e possiveis."
            android:textColor="@color/muted"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
