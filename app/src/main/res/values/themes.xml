<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HabitApp.Common" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/study</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/success</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorOutline">@color/line</item>
        <item name="colorControlHighlight">@color/tab_ripple</item>
        <item name="android:statusBarColor">@color/screen_start</item>
        <item name="android:navigationBarColor">@color/nav_shell</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="materialButtonStyle">@style/Widget.HabitApp.Button</item>
        <item name="materialCardViewStyle">@style/Widget.HabitApp.Card</item>
        <item name="chipStyle">@style/Widget.HabitApp.Chip</item>
    </style>

    <style name="Widget.HabitApp.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/wellness_card_radius</item>
        <item name="cardElevation">6dp</item>
        <item name="strokeColor">@color/line</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.HabitApp.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/wellness_button_radius</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.HabitApp.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/wellness_chip_radius</item>
        <item name="chipMinHeight">40dp</item>
        <item name="chipStrokeColor">@color/line</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <style name="Base.Theme.HabitApp" parent="Base.Theme.HabitApp.Common" />

    <style name="Theme.HabitApp" parent="Base.Theme.HabitApp" />
</resources>
